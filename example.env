# Copy this file to .env and fill in local credentials/paths.

# Agent planning model
AGENT_BASE_URL=
AGENT_MODEL=
AGENT_API_KEY=
AGENT_MAX_ITERATIONS=30

# LLM operation model for llm_map/llm_reduce/BlendSQL ingredients
LLMOP_BASE_URL=
LLMOP_MODEL=
LLMOP_API_KEY=
LLMOP_TIMEOUT_S=3600
LLMOP_CONCURRENCY=4

# Optional separate model for learning distillation. Defaults to AGENT_* when unset.
LEARNING_LLM_BASE_URL=
LEARNING_LLM_MODEL=
LEARNING_LLM_API_KEY=

# SWAN database location and run controls
DB_FILES_DIR=/path/to/swan/database
QUERY_TIMEOUT_S=600
QUERY_CONCURRENCY=4

# MCP/server behavior
MCP_RESULT_MAX_CHARS=20000

# Optional external MCP override
DB_MCP_COMMAND=
DB_MCP_ARGS_JSON=
DB_MCP_ENV_JSON=
DB_MCP_SERVER_NAME=

# Optional AWS credentials, only needed when using Bedrock-backed models.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=

# Optional local sandbox settings
SANDBOX_DIR=./sandbox
